# ================================
# SaSa Backend — Environment Config
# Copy this to .env and fill values
# ================================

# --- Database ---
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/sasa_db

# --- JWT Auth ---
JWT_SECRET=replace-this-with-a-random-32-char-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Server ---
PORT=4000
NODE_ENV=development

# --- Python Engine ---
# Path to the Python engine entrypoint (relative to backend/)
PYTHON_ENGINE_PATH=../python-engine/main.py
PYTHON_BIN=python   # use 'python3' on Linux/macOS if needed

# --- Puppeteer (PDF) ---
# Leave blank to use bundled Chromium; set path for custom Chrome install
PUPPETEER_EXECUTABLE_PATH=
